# Database
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/ai_context

# GitNexus
GITNEXUS_HOME=/mnt/nfs/repos/.gitnexus
GITNEXUS_SERVE_URL=http://localhost:4747
GITNEXUS_CLI_PATH=gitnexus

# Storage
REPOS_ROOT_DIR=/mnt/nfs/repos

# Index
MAX_CONCURRENT_INDEX_JOBS=3

# Wiki generation (requires OPENAI_API_KEY if include_wiki=true)
OPENAI_API_KEY=
GITNEXUS_WIKI_MODEL=gpt-4o-mini

# Auth
JWT_SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_URL=redis://localhost:6379/0

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ai-context

# Encryption (AES-256-GCM for GitLab credentials)
GITLAB_ENCRYPTION_KEY=change-me-32-bytes-aes-key!!!!

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
