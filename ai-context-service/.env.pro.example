# ============================================
# AI Context Service - Production Config
# 启动方式: APP_ENV=pro uvicorn app.main:app
# 复制为 .env.pro 并填入真实值
# ============================================

# Database
DATABASE_URL=mysql+aiomysql://ai_context:<PASSWORD>@mysql.prod:3306/ai_context

# GitNexus
GITNEXUS_HOME=/mnt/nfs/repos/.gitnexus
GITNEXUS_SERVE_URL=http://gitnexus.prod:4747
GITNEXUS_CLI_PATH=gitnexus

# Storage (NFS)
REPOS_ROOT_DIR=/mnt/nfs/repos

# Index
MAX_CONCURRENT_INDEX_JOBS=5

# Wiki generation
OPENAI_API_KEY=
GITNEXUS_WIKI_MODEL=gpt-4o-mini

# Auth
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_URL=redis://redis.prod:6379/0

# S3 / MinIO
S3_ENDPOINT=http://minio.prod:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=ai-context
S3_REGION=

# Encryption (AES-256-GCM)
GITLAB_ENCRYPTION_KEY=

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=WARNING
